__pycache__/
*.pyc
.DS_Store

# Sandbox artifacts that can't be deleted from inside Cowork
zzz-*
*.lock

# Secrets — never commit these (and any editor swap copies)
.gh-token*
.repo-url*

# Editor / OS cruft
*.swp
*.swo
*~
.DS_Store

# Drop zones for ad-hoc input files
data/inputs/*
data/processed/*
!data/inputs/.gitkeep
!data/processed/.gitkeep
